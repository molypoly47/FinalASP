<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Room Reservation</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Room Reservation</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            @{ var ctrl = ViewContext.RouteData.Values["controller"]?.ToString(); }
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @(ctrl == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ctrl == "Rooms" ? "active" : "")" asp-controller="Rooms" asp-action="Index">Rooms</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ctrl == "Reservations" ? "active" : "")" asp-controller="Reservations" asp-action="Index">Reservations</a>
                </li>
            </ul>
            <a class="btn btn-warning btn-sm" asp-controller="Reservations" asp-action="Create">+ New Booking</a>
        </div>
    </div>
</nav>

<div class="container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
