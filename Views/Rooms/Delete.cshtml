@model RoomReservation.Models.Room
@{ ViewData["Title"] = "Delete Room"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Rooms" asp-action="Index">Rooms</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>

<div class="card border-danger" style="max-width: 500px;">
    <div class="card-header bg-danger text-white">Confirm Delete</div>
    <div class="card-body">
        <p>Are you sure you want to delete this room?</p>
        <dl class="row">
            <dt class="col-sm-4">Room Name</dt>
            <dd class="col-sm-8">@Model.RoomName</dd>
            <dt class="col-sm-4">Type</dt>
            <dd class="col-sm-8">@Model.RoomType</dd>
            <dt class="col-sm-4">Price / Night</dt>
            <dd class="col-sm-8">₱@Model.PricePerNight.ToString("N2")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.RoomId" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
