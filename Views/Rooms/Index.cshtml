@model IEnumerable<RoomReservation.Models.Room>
@{ ViewData["Title"] = "Rooms"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Rooms</h3>
    <a asp-action="Create" class="btn btn-primary">+ Add Room</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-primary">
            <tr>
                <th>Room Name</th>
                <th>Type</th>
                <th>Capacity</th>
                <th>Price / Night</th>
                <th>Available</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.RoomName</td>
                    <td>@room.RoomType</td>
                    <td>@room.Capacity</td>
                    <td>₱@room.PricePerNight.ToString("N2")</td>
                    <td>
                        @if (room.IsAvailable)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@room.RoomId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit"    asp-route-id="@room.RoomId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete"  asp-route-id="@room.RoomId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted">No rooms found.</td></tr>
            }
        </tbody>
    </table>
</div>
