@model RoomReservation.Models.Room
@{ ViewData["Title"] = "Edit Room"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Rooms" asp-action="Index">Rooms</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<h3 class="mb-3">Edit Room</h3>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="RoomId" type="hidden" />

            <div class="mb-3">
                <label asp-for="RoomName" class="form-label"></label>
                <input asp-for="RoomName" class="form-control" />
                <span asp-validation-for="RoomName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RoomType" class="form-label"></label>
                <select asp-for="RoomType" class="form-select">
                    @foreach (var t in (string[])ViewBag.RoomTypes)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <span asp-validation-for="RoomType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Capacity" class="form-label"></label>
                <input asp-for="Capacity" type="number" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PricePerNight" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">₱</span>
                    <input asp-for="PricePerNight" type="number" step="0.01" class="form-control" />
                </div>
                <span asp-validation-for="PricePerNight" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                    <label asp-for="IsAvailable" class="form-check-label">Available</label>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
