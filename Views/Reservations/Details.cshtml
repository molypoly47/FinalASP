@model RoomReservation.Models.Reservation
@{ ViewData["Title"] = "Reservation Details"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Reservations" asp-action="Index">Reservations</a></li>
        <li class="breadcrumb-item active">Details</li>
    </ol>
</nav>

<h3 class="mb-3">Reservation #@Model.ReservationId</h3>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Guest Name</dt>
            <dd class="col-sm-8">@Model.GuestName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.GuestEmail</dd>

            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.GuestPhone</dd>

            <dt class="col-sm-4">Room</dt>
            <dd class="col-sm-8">@Model.Room?.RoomName (@Model.Room?.RoomType)</dd>

            <dt class="col-sm-4">Check-In</dt>
            <dd class="col-sm-8">@Model.CheckIn.ToString("MMMM dd, yyyy")</dd>

            <dt class="col-sm-4">Check-Out</dt>
            <dd class="col-sm-8">@Model.CheckOut.ToString("MMMM dd, yyyy")</dd>

            <dt class="col-sm-4">Nights</dt>
            <dd class="col-sm-8">@Model.TotalNights</dd>

            <dt class="col-sm-4">Total</dt>
            <dd class="col-sm-8">₱@Model.TotalAmount.ToString("N2")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @{
                    var cls = Model.Status switch {
                        "Confirmed"   => "bg-success",
                        "Pending"     => "bg-warning text-dark",
                        "Checked-In"  => "bg-primary",
                        "Checked-Out" => "bg-secondary",
                        "Cancelled"   => "bg-danger",
                        _             => "bg-light text-dark"
                    };
                }
                <span class="badge @cls">@Model.Status</span>
            </dd>

            <dt class="col-sm-4">Special Requests</dt>
            <dd class="col-sm-8">@(Model.SpecialRequests ?? "—")</dd>

            <dt class="col-sm-4">Date Created</dt>
            <dd class="col-sm-8">@Model.DateCreated.ToString("MMM dd, yyyy")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit"   asp-route-id="@Model.ReservationId" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.ReservationId" class="btn btn-danger">Delete</a>
    <a asp-action="Index"                                       class="btn btn-secondary">Back</a>
</div>
