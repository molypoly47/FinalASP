@model RoomReservation.Models.Reservation
@{ ViewData["Title"] = "Delete Reservation"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Reservations" asp-action="Index">Reservations</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>

<div class="card border-danger" style="max-width: 500px;">
    <div class="card-header bg-danger text-white">Confirm Delete</div>
    <div class="card-body">
        <p>Are you sure you want to delete this reservation?</p>
        <dl class="row">
            <dt class="col-sm-4">Guest</dt>
            <dd class="col-sm-8">@Model.GuestName</dd>
            <dt class="col-sm-4">Room</dt>
            <dd class="col-sm-8">@Model.Room?.RoomName</dd>
            <dt class="col-sm-4">Check-In</dt>
            <dd class="col-sm-8">@Model.CheckIn.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-4">Check-Out</dt>
            <dd class="col-sm-8">@Model.CheckOut.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-4">Total</dt>
            <dd class="col-sm-8">₱@Model.TotalAmount.ToString("N2")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ReservationId" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
